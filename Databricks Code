## EDA



CREATE OR REPLACE TABLE layoffs_clean AS
SELECT 
    company,
    location,
    TRIM(industry) AS industry,
    TRY_CAST(total_laid_off AS INT) AS total_laid_off,
    TRY_CAST(percentage_laid_off AS DOUBLE) AS percentage_laid_off,
    to_date(date) AS date,
    stage,
    TRIM(country) AS country,
    TRY_CAST(funds_raised_millions AS DOUBLE) AS funds_raised_millions
FROM layoffs_staging2;

SELECT * 
FROM layoffs_clean;
SELECT MAX (total_laid_off)
FROM layoffs_clean;

## Industry that was hit the most
SELECT industry, SUM (total_laid_off)
FROM layoffs_clean
WHERE company = 'Cancstar'
Group by industry
ORDER BY SUM(total_laid_off
) DESC;

## Company that layedd off the most
SELECT company, SUM(total_laid_off)
FROM layoffs_clean
GROUP BY company
ORDER BY SUM(total_laid_off) DESC;

## Country that was affected the most 

SELECT country, SUM(total_laid_off)
FROM layoffs_clean
GROUP BY country
ORDER BY 2 DESC;

## Year that was affected the most
SELECT Year(`date`), SUM(total_laid_off)
FROM layoffs_clean
GROUP BY 1
ORDER BY 1 DESC;


SELECT stage, SUM(total_laid_off)
FROM layoffs_clean
GROUP BY 1
ORDER BY 2 DESC;

## Percentage Layed off

SELECT company, AVG(percentage_laid_off)
FROM layoffs_clean
GROUP BY 1
ORDER BY 2 DESC;

## Progression of the Lay Offs Per Month of each Year

SELECT substring(`date`, 1,7 ) AS Month_Y, SUM(total_laid_off)
FROM layoffs_clean
GROUP BY 1
ORDER BY 1 ASC;

WITH Rolling_Total AS(
SELECT substring(`date`, 1,7 ) AS Month_Y, SUM(total_laid_off) AS total_off
FROM layoffs_clean
WHERE substring(`date`, 1,7 ) IS NOT NULL
GROUP BY 1
ORDER BY 1 ASC)

SELECT Month_Y , total_off, SUM(total_off) Over (ORDER BY Month_Y) As rolling_Total
FROM Rolling_Total;


## Top 5 Companies with the Lay Offs Per Year 


WITH Company_Year AS(
SELECT company,  Year(`date`) AS Y, SUM(total_laid_off) AS total_off, AVG(percentage_laid_off) AS AVG_percentage
FROM layoffs_clean
WHERE ( `date` IS NOT NULL )
GROUP BY 1,2
HAVING  (SUM(total_laid_off)) IS NOT NULL AND AVG(percentage_laid_off) IS NOT NULL
),

Ranked As(SELECT *,
DENSE_RANK() OVER (PARTITION BY Y  ORDER BY total_off DESC) AS Ranking
FROM Company_Year)
SELECT *
FROM Ranked
WHERE ranking <= 5
ORDER BY Y, ranking;
